---
/**
 * VideoCard.astro — Horizontal layout: big embed on left, info on right.
 * Stacks vertically on mobile.
 */
import LiteYoutube from './LiteYoutube.astro';

interface Props {
  id: string;
  title: string;
  description: string;
}

const { id, title, description } = Astro.props;
---

<article class="video-card">
  <div class="vc-embed">
    <LiteYoutube id={id} title={title} />
  </div>
  <div class="vc-info">
    <h3>{title}</h3>
    <p>{description}</p>
  </div>
</article>

<style>
  .video-card {
    display: grid;
    grid-template-columns: 3fr 2fr;
    gap: 1.75rem;
    align-items: start;
    max-width: 850px;
  }

  .vc-embed {
    border-radius: 10px;
    overflow: hidden;
  }

  .vc-info h3 {
    font-size: 1.1rem;
    font-weight: 600;
    margin: 0 0 0.6rem;
    color: var(--text, #f0f0f0);
  }

  .vc-info p {
    font-size: 0.88rem;
    color: var(--text-muted, #a0a0a0);
    line-height: 1.6;
    margin: 0;
  }

  @media (max-width: 600px) {
    .video-card {
      grid-template-columns: 1fr;
      gap: 0.75rem;
    }
  }
</style>
