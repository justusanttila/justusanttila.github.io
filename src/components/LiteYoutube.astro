---
/**
 * LiteYoutube.astro — Shows thumbnail + play button, loads iframe only on click.
 * Reduces page weight significantly vs eager iframes.
 */
interface Props {
  id: string;
  title: string;
}

const { id, title } = Astro.props;
---

<div class="lite-yt" data-video-id={id} data-video-title={title}>
  <img
    src={`https://i.ytimg.com/vi/${id}/hqdefault.jpg`}
    alt={title}
    loading="lazy"
    decoding="async"
  />
  <button class="yt-play-btn" type="button" aria-label={`Toista: ${title}`}>
    <svg viewBox="0 0 68 48" width="68" height="48" aria-hidden="true" focusable="false">
      <path d="M66.5 7.4A8.7 8.7 0 0 0 60.7 1.4C55.4 0 34 0 34 0S12.6 0 7.3 1.4A8.7 8.7 0 0 0 1.5 7.4C0 12.8 0 24 0 24s0 11.2 1.5 16.6A8.7 8.7 0 0 0 7.3 46.6C12.6 48 34 48 34 48s21.4 0 26.7-1.4a8.7 8.7 0 0 0 5.8-6C68 35.2 68 24 68 24s0-11.2-1.5-16.6z" fill="#ff0000"/>
      <path d="M45 24 27 14v20z" fill="#fff"/>
    </svg>
  </button>
</div>

<style>
  .lite-yt {
    position: relative;
    width: 100%;
    aspect-ratio: 16/9;
    cursor: pointer;
    background: #000;
    overflow: hidden;
  }

  .lite-yt img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: filter 0.3s ease;
  }

  .lite-yt:hover img {
    filter: brightness(0.65);
  }

  .yt-play-btn {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    background: none;
    border: none;
    cursor: pointer;
    padding: 0;
    -webkit-tap-highlight-color: transparent;
  }

  .yt-play-btn svg {
    filter: drop-shadow(0 2px 10px rgba(0,0,0,0.7));
    transition: transform 0.2s ease, filter 0.2s ease;
  }

  .lite-yt:hover .yt-play-btn svg {
    transform: scale(1.12);
    filter: drop-shadow(0 4px 20px rgba(0,0,0,0.9));
  }

  .lite-yt iframe {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    border: none;
  }
</style>

<script>
  let didWarmConnections = false;

  function warmConnections() {
    if (didWarmConnections) return;
    didWarmConnections = true;

    const origins = [
      'https://www.youtube-nocookie.com',
      'https://www.google.com',
      'https://www.googlevideo.com',
      'https://i.ytimg.com',
      'https://s.ytimg.com',
    ];

    origins.forEach((href) => {
      const link = document.createElement('link');
      link.rel = 'preconnect';
      link.href = href;
      link.crossOrigin = '';
      document.head.appendChild(link);
    });
  }

  function buildEmbedSrc(id: string, autoplay: boolean) {
    return `https://www.youtube-nocookie.com/embed/${id}?autoplay=${autoplay ? '1' : '0'}&rel=0&modestbranding=1&playsinline=1`;
  }

  function createIframe(id: string, title: string, autoplay: boolean) {
    const iframe = document.createElement('iframe');
    iframe.src = buildEmbedSrc(id, autoplay);
    iframe.title = title;
    iframe.allow =
      'accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture';
    iframe.allowFullscreen = true;
    // Astro's scoped CSS won't apply to dynamically-created elements, so set inline:
    iframe.style.cssText = 'position:absolute;inset:0;width:100%;height:100%;border:none';
    return iframe;
  }

  function prewarmIframe(el: HTMLDivElement) {
    if (el.dataset.prewarmed === '1' || el.querySelector('iframe')) return;

    const id = el.dataset.videoId!;
    const title = el.dataset.videoTitle ?? '';
    const iframe = createIframe(id, title, false);
    iframe.style.opacity = '0';
    iframe.style.pointerEvents = 'none';
    el.appendChild(iframe);
    el.dataset.prewarmed = '1';
  }

  document.querySelectorAll<HTMLDivElement>('.lite-yt').forEach((el) => {
    const prewarm = () => {
      warmConnections();
      prewarmIframe(el);
    };

    el.addEventListener('pointerenter', warmConnections, { once: true });
    el.addEventListener('focusin', prewarm, { once: true });
    el.addEventListener('pointerdown', prewarm, { once: true });
    el.addEventListener('touchstart', prewarm, { once: true, passive: true });

    el.addEventListener('click', () => {
      warmConnections();

      const id = el.dataset.videoId!;
      const title = el.dataset.videoTitle ?? '';
      let iframe = el.querySelector('iframe');

      if (!iframe) {
        iframe = createIframe(id, title, true);
        el.appendChild(iframe);
      } else {
        iframe.src = buildEmbedSrc(id, true);
        iframe.style.opacity = '1';
        iframe.style.pointerEvents = 'auto';
      }

      // Hide thumbnail and play button
      el.querySelector('img')?.remove();
      el.querySelector('.yt-play-btn')?.remove();
    });
  });
</script>
