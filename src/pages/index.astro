---
import BaseLayout from '../layouts/BaseLayout.astro';
import Nav from '../components/Nav.astro';
import VideoCard from '../components/VideoCard.astro';
import PortfolioSection from '../components/PortfolioSection.astro';
import FaqAccordion from '../components/FaqAccordion.astro';
import ContactForm from '../components/ContactForm.astro';
import { home, portfolio, pricing as pricingContent, contact, meta } from '../data/content.js';
import { getFeaturedVideos } from '../data/videos.js';
import { services, faq } from '../data/pricing.js';

const featured = getFeaturedVideos();
---

<BaseLayout
  title={home.pageTitle}
  description={home.metaDescription}
>
  <Nav />

  <main id="main-content">

    <!-- HOME -->
    <section class="page-section" data-section="home">

      <div class="hero">
        <video class="hero-bg" autoplay loop muted playsinline
               poster="/img/kansivideo.jpg" aria-hidden="true">
          <source src="/img/kansivideo.webm" type="video/webm" />
        </video>
        <div class="hero-content">
          <video class="hero-logo" autoplay muted playsinline
                 aria-label="Justus Anttila animaatio">
            <source src="/img/tekstianimaatio.webm" type="video/webm" />
          </video>
          <h1 class="hero-title">{home.heroTitle}</h1>
        </div>
      </div>

      <div class="section-block reveal">
        <div class="about-grid">
          <div>
            <div class="social-links">
              <a href={meta.youtubeUrl} target="_blank" rel="noopener noreferrer" aria-label="YouTube-kanava">
                <img src="/img/youtubesvg.svg" alt="YouTube" />
              </a>
              <a href={meta.instagramUrl} target="_blank" rel="noopener noreferrer" aria-label="Instagram">
                <img src="/img/instagramsvg.svg" alt="Instagram" />
              </a>
            </div>
            <h2>{home.aboutHeading}</h2>
            {home.aboutParagraphs.map((p) => <p>{p}</p>)}
          </div>
          <div>
            <img class="about-img" src="/img/profiilikuva.jpg" alt="Justus Anttila" loading="lazy" />
          </div>
        </div>
      </div>

      <div class="section-block reveal reveal-delay-1">
        <h2>{home.portfolioTeaserHeading}</h2>
        <p>{home.portfolioTeaserText}</p>
        <div class="featured-list">
          {featured.map((v) => (
            <div class="featured-list-item">
              <VideoCard id={v.id} title={v.title} description={v.description ?? v.categoryLabel} />
            </div>
          ))}
        </div>
        <button class="btn btn-primary" data-nav="portfolio" style="margin-top:1.25rem">
          {home.portfolioTeaserCta}
        </button>
      </div>

      <div class="section-block reveal reveal-delay-2">
        <h2>{home.pricingTeaserHeading}</h2>
        <p>{home.pricingTeaserText}</p>
        <div class="pricing-teaser">
          {services.slice(0, 3).map((s) => (
            <div class="pricing-teaser-item">
              <h3>{s.title}</h3>
              <p class="price">{s.price}</p>
            </div>
          ))}
        </div>
        <button class="btn btn-ghost" data-nav="hinnasto">
          {home.pricingTeaserCta}
        </button>
      </div>

      <div class="section-block reveal reveal-delay-3">
        <h2>{home.contactTeaserHeading}</h2>
        <p>
          Voit ottaa minuun yhteyttä sähköpostilla{' '}
          <a href={`mailto:${meta.email}`}>{meta.email}</a>.
          Kerro kuka olet, millaista videota tarvitset ja alustava ajankohta.
        </p>
        <button class="btn btn-primary" data-nav="yhteydenotto">
          {home.contactTeaserCta}
        </button>
      </div>

    </section>

    <!-- PORTFOLIO -->
    <section class="page-section" data-section="portfolio">

      <div class="section-block reveal">
        <h1>{portfolio.heading}</h1>
        <p>{portfolio.intro}</p>
        <PortfolioSection />
      </div>

      <div class="section-block reveal">
        <h2>{portfolio.ctaHeading}</h2>
        <p>{portfolio.ctaText}</p>
        <button class="btn btn-primary" data-nav="yhteydenotto">
          {portfolio.ctaButton}
        </button>
      </div>

    </section>

    <!-- HINNASTO -->
    <section class="page-section" data-section="hinnasto">

      <div class="section-block reveal">
        <h1>{pricingContent.heading}</h1>
        <p>{pricingContent.intro}</p>
      </div>

      <div class="section-block reveal">
        <h2>{pricingContent.servicesHeading}</h2>
        <div class="pricing-grid">
          {services.map((s) => (
            <article class="pricing-card">
              <h3>{s.title}</h3>
              <p class="price">{s.price}</p>
              <p>{s.description}</p>
              <button class="btn btn-primary" data-nav="yhteydenotto">
                {pricingContent.ctaButton}
              </button>
            </article>
          ))}
        </div>
      </div>

      <div class="section-block reveal">
        <h2>{pricingContent.faqHeading}</h2>
        <p>{pricingContent.faqIntro}</p>
        <FaqAccordion items={faq} />
      </div>

    </section>

    <!-- YHTEYDENOTTO -->
    <section class="page-section" data-section="yhteydenotto">

      <div class="section-block reveal">
        <h1>{contact.heading}</h1>
        <p>
          {contact.intro} Sähköposti: <a href={`mailto:${meta.email}`}>{meta.email}</a>.
        </p>
        <ContactForm />
      </div>

    </section>

  </main>

  <footer class="site-footer">
    <span>Y-tunnus: {meta.businessId}</span>
    <span>{meta.postalCode} {meta.city}</span>
  </footer>

  <script
    src="https://cdn.jsdelivr.net/npm/@emailjs/browser@4/dist/email.min.js"
    is:inline
  ></script>

  <script>
    import '../scripts/app.js';
  </script>

</BaseLayout>

<style>
  .hero {
    position: relative;
    overflow: hidden;
    min-height: clamp(280px, 52vh, 580px);
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .hero-bg {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    filter: brightness(0.4);
    z-index: 0;
  }
  .hero-content {
    position: relative;
    z-index: 2;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.5rem;
    padding: 2rem 1rem;
    text-align: center;
  }
  .hero-logo {
    width: min(68vw, 460px);
    height: auto;
    animation: heroLogoFade 1.4s cubic-bezier(0.4,0,0.2,1) both;
  }
  .hero-title {
    font-size: clamp(1.2rem, 4vw, 2.25rem);
    font-weight: 700;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: rgba(255,255,255,0.75);
    text-shadow: 0 2px 16px rgba(0,0,0,0.8);
    margin: 0;
    user-select: none;
    -webkit-user-select: none;
    animation: heroTitleFade 1.8s cubic-bezier(0.4,0,0.2,1) 0.7s both;
  }
  @keyframes heroLogoFade {
    from { opacity: 0; transform: translateY(-10px); }
    to   { opacity: 1; transform: translateY(0); }
  }
  @keyframes heroTitleFade {
    from { opacity: 0; transform: translateY(8px); }
    to   { opacity: 1; transform: translateY(0); }
  }
  .featured-list {
    display: flex;
    flex-direction: column;
    gap: 0;
    margin: 1.25rem 0 0;
  }
  .featured-list-item {
    padding: 1.5rem 0;
    border-bottom: 1px solid rgba(255,255,255,0.06);
  }
  .featured-list-item:first-child { padding-top: 0; }
  .featured-list-item:last-child  { border-bottom: none; padding-bottom: 0; }
</style>